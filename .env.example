NODE_ENV=production
PORT=3000

# URL de Acesso do Sistema (Frontend e Backend)
APP_URL=https://odontocontrol.wapainel.com.br
VITE_APP_URL=https://odontocontrol.wapainel.com.br

# Conexão com o Banco de Dados PostgreSQL/pgvector
DATABASE_URL=postgresql://odontocontrol:TROQUE_ESSA_SENHA_FORTE@localhost:5432/odontocontrol
DB_SSL=false

# Configurações do Better Auth
# Gere o secret usando: openssl rand -base64 48
BETTER_AUTH_SECRET=TROQUE_ESSE_SECRET_FORTE
BETTER_AUTH_URL=https://odontocontrol.wapainel.com.br

# Configurações de Bootstrap de Super Admin (Opcional - Trocar após primeiro login)
BOOTSTRAP_ADMIN_EMAIL=admin@admin.com
BOOTSTRAP_ADMIN_PASSWORD=@Admin.com
